generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  ESTUDIANTE
  PROFESOR
  ADMIN
}

enum EstadoProfesor {
  PENDIENTE
  VERIFICADO
  RECHAZADO
}

enum EstadoSesion {
  PENDIENTE
  CONFIRMADA
  COMPLETADA
  CANCELADA
}

enum ModalidadSesion {
  VIRTUAL
  PRESENCIAL
}

enum NivelAcademico {
  SECUNDARIA
  TECNICA
  UNIVERSITARIA
}

enum EstadoDisponibilidad {
  DISPONIBLE
  EN_CLASE
  NO_DISPONIBLE
}

enum EstadoRetiro {
  PENDIENTE
  APROBADO
  RECHAZADO
  PAGADO
}

enum NivelVerificacion {
  BASICO       // identidad (DNI)
  EXPERTO      // conocimiento (certificados/proyectos)
  DOCENTE      // título universitario + experiencia
}

enum TipoCredencial {
  IDENTIDAD       // DNI + selfie
  TITULO          // título universitario / técnico
  CERTIFICADO     // curso online (Coursera, edX, Platzi)
  RECORD          // intranet universitaria (mostrar nota)
  PROYECTO        // GitHub, portfolio
  EXPERIENCIA     // LinkedIn / carta laboral
  EXAMEN_INTERNO  // pasó el examen de ProfeLink
}

enum EstadoCredencial {
  PENDIENTE
  APROBADA
  RECHAZADA
}

enum TipoCupon {
  PRIMERA_GRATIS    // 1 sesión gratis para nuevos estudiantes
  REFERIDO          // por referir amigo
  DESCUENTO_FIJO    // S/X menos en próxima sesión
  PORCENTAJE        // % de descuento
}

enum EstadoCupon {
  ACTIVO
  USADO
  EXPIRADO
}

model Usuario {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre           String     @db.VarChar(120)
  email            String     @unique @db.VarChar(255)
  passwordHash     String     @map("password_hash")
  rol              RolUsuario
  activo           Boolean    @default(true)
  emailVerificado  Boolean    @default(false) @map("email_verificado")
  intentosFallidos Int        @default(0) @map("intentos_fallidos")
  bloqueadoHasta   DateTime?  @map("bloqueado_hasta") @db.Timestamptz()
  totpSecret       String?    @map("totp_secret")
  totpHabilitado   Boolean    @default(false) @map("totp_habilitado")
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  perfilProfesor PerfilProfesor?
  sesionesComoEstudiante Sesion[]  @relation("EstudianteSesiones")
  resenasEscritas        Resena[]  @relation("EstudianteResenas")
  mensajesEnviados       Mensaje[] @relation("MensajesEnviados")
  notificaciones         Notificacion[]
  tokensPasswordReset    TokenPasswordReset[]
  tokensEmailVerif       TokenEmailVerificacion[]
  cupones                Cupon[]
  favoritos              Favorito[]

  @@map("usuarios")
}

model Favorito {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estudianteId String   @map("estudiante_id") @db.Uuid
  profesorId   String   @map("profesor_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  estudiante   Usuario        @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  profesor     PerfilProfesor @relation(fields: [profesorId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, profesorId])
  @@map("favoritos")
}

model Notificacion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId  String   @map("usuario_id") @db.Uuid
  tipo       String   @db.VarChar(40)
  titulo     String   @db.VarChar(120)
  mensaje    String
  url        String?  @db.VarChar(200)
  leida      Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

model TokenPasswordReset {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId  String   @map("usuario_id") @db.Uuid
  token      String   @unique @db.VarChar(120)
  expiraEn   DateTime @map("expira_en") @db.Timestamptz()
  usado      Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tokens_password_reset")
}

model TokenEmailVerificacion {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId  String   @map("usuario_id") @db.Uuid
  token      String   @unique @db.VarChar(120)
  expiraEn   DateTime @map("expira_en") @db.Timestamptz()
  usado      Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tokens_email_verificacion")
}

model PerfilProfesor {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId          String            @unique @map("usuario_id") @db.Uuid
  fotoUrl            String?           @map("foto_url")
  videoPresentacion  String?           @map("video_presentacion")
  bio                String?
  nivel              NivelAcademico[]
  precioHora         Decimal           @map("precio_hora") @db.Decimal(8, 2)
  precio30min        Decimal?          @map("precio_30min") @db.Decimal(8, 2)
  aceptaPrimeraGratis Boolean          @default(false) @map("acepta_primera_gratis")
  modalidad          ModalidadSesion   @default(VIRTUAL)
  estado             EstadoProfesor    @default(PENDIENTE)
  nivelVerificacion  NivelVerificacion @default(BASICO) @map("nivel_verificacion")
  ciudad             String?           @db.VarChar(80)
  anosExperiencia    Int               @default(0) @map("anos_experiencia")
  institucion        String?           @db.VarChar(120)
  ratingPromedio     Decimal           @default(0) @map("rating_promedio") @db.Decimal(3, 2)
  totalResenas       Int               @default(0) @map("total_resenas")
  estadoDisponibilidad EstadoDisponibilidad @default(DISPONIBLE) @map("estado_disponibilidad")
  mensajeAutoRespuesta String?         @map("mensaje_auto_respuesta")
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  usuario         Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  especialidades  Especialidad[]
  disponibilidad  Disponibilidad[]
  sesiones        Sesion[]         @relation("ProfesorSesiones")
  resenas         Resena[]         @relation("ProfesorResenas")
  retiros         SolicitudRetiro[]
  credenciales    Credencial[]
  favoritedBy     Favorito[]

  @@map("perfiles_profesor")
}

model Credencial {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId      String           @map("profesor_id") @db.Uuid
  tipo            TipoCredencial
  titulo          String           @db.VarChar(200)
  descripcion     String?
  archivoUrl      String?          @map("archivo_url")
  enlaceExterno   String?          @map("enlace_externo") @db.VarChar(500)
  estado          EstadoCredencial @default(PENDIENTE)
  notaAdmin       String?          @map("nota_admin")
  revisadoEn      DateTime?        @map("revisado_en") @db.Timestamptz()
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  profesor        PerfilProfesor   @relation(fields: [profesorId], references: [id], onDelete: Cascade)

  @@index([profesorId, estado])
  @@map("credenciales")
}

model Cupon {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId     String       @map("usuario_id") @db.Uuid
  codigo        String       @unique @db.VarChar(40)
  tipo          TipoCupon
  valor         Decimal      @default(0) @db.Decimal(8, 2)
  estado        EstadoCupon  @default(ACTIVO)
  expiraEn      DateTime?    @map("expira_en") @db.Timestamptz()
  usadoEnSesion String?      @map("usado_en_sesion") @db.Uuid
  usadoEn       DateTime?    @map("usado_en") @db.Timestamptz()
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  usuario       Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, estado])
  @@map("cupones")
}

model SolicitudRetiro {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId    String       @map("profesor_id") @db.Uuid
  monto         Decimal      @db.Decimal(10, 2)
  metodo        String       @db.VarChar(40)
  cuentaDestino String       @map("cuenta_destino") @db.VarChar(120)
  estado        EstadoRetiro @default(PENDIENTE)
  notaAdmin     String?      @map("nota_admin")
  procesadoEn   DateTime?    @map("procesado_en") @db.Timestamptz()
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  profesor      PerfilProfesor @relation(fields: [profesorId], references: [id], onDelete: Cascade)

  @@index([profesorId, estado])
  @@map("solicitudes_retiro")
}

model Especialidad {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId String   @map("profesor_id") @db.Uuid
  materia    String   @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  profesor   PerfilProfesor @relation(fields: [profesorId], references: [id], onDelete: Cascade)

  @@map("especialidades")
}

model Disponibilidad {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId  String   @map("profesor_id") @db.Uuid
  diaSemana   Int      @map("dia_semana") @db.SmallInt
  horaInicio  DateTime @map("hora_inicio") @db.Time()
  horaFin     DateTime @map("hora_fin") @db.Time()
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  profesor    PerfilProfesor @relation(fields: [profesorId], references: [id], onDelete: Cascade)

  @@map("disponibilidad")
}

model Sesion {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estudianteId    String          @map("estudiante_id") @db.Uuid
  profesorId      String          @map("profesor_id") @db.Uuid
  fechaInicio     DateTime        @map("fecha_inicio") @db.Timestamptz()
  fechaFin        DateTime        @map("fecha_fin") @db.Timestamptz()
  modalidad       ModalidadSesion
  estado          EstadoSesion    @default(PENDIENTE)
  duracionMinutos Int             @default(60) @map("duracion_minutos")
  precioAcordado  Decimal         @map("precio_acordado") @db.Decimal(8, 2)
  descuentoCupon  Decimal         @default(0) @map("descuento_cupon") @db.Decimal(8, 2)
  cuponCodigo     String?         @map("cupon_codigo") @db.VarChar(40)
  notas           String?
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  esGrupal        Boolean         @default(false) @map("es_grupal")
  capacidadMax    Int             @default(1) @map("capacidad_max")

  estudiante      Usuario        @relation("EstudianteSesiones", fields: [estudianteId], references: [id], onDelete: Cascade)
  profesor        PerfilProfesor @relation("ProfesorSesiones",   fields: [profesorId],   references: [id], onDelete: Cascade)
  resena          Resena?
  mensajes        Mensaje[]
  tareas          Tarea[]
  participantes   ParticipanteGrupal[]

  @@map("sesiones")
}

model Tarea {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sesionId    String   @map("sesion_id") @db.Uuid
  titulo      String   @db.VarChar(200)
  descripcion String?
  archivoUrl  String?  @map("archivo_url")
  completada  Boolean  @default(false)
  respuesta   String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  completadaEn DateTime? @map("completada_en") @db.Timestamptz()

  sesion      Sesion   @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@index([sesionId])
  @@map("tareas")
}

model NotaPrivada {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId   String   @map("profesor_id") @db.Uuid
  estudianteId String   @map("estudiante_id") @db.Uuid
  contenido    String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([profesorId, estudianteId])
  @@map("notas_privadas")
}

model Material {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sesionId   String   @map("sesion_id") @db.Uuid
  titulo     String   @db.VarChar(200)
  archivoUrl String   @map("archivo_url")
  subidoPor  String   @map("subido_por") @db.VarChar(20) // 'PROFESOR' o 'ESTUDIANTE'
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([sesionId])
  @@map("materiales")
}

model ListaEspera {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estudianteId String   @map("estudiante_id") @db.Uuid
  profesorId   String   @map("profesor_id") @db.Uuid
  diaSemana    Int      @map("dia_semana") @db.SmallInt
  hora         String   @db.VarChar(5)
  notificado   Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([estudianteId, profesorId, diaSemana, hora])
  @@map("lista_espera")
}

model Wishlist {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  estudianteId String   @map("estudiante_id") @db.Uuid
  materia      String   @db.VarChar(120)
  descripcion  String?
  resuelto     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([estudianteId])
  @@index([materia])
  @@map("wishlist")
}

model ParticipanteGrupal {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sesionId     String   @map("sesion_id") @db.Uuid
  estudianteId String   @map("estudiante_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  sesion       Sesion   @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@unique([sesionId, estudianteId])
  @@map("participantes_grupales")
}

model PlantillaMensaje {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId  String   @map("profesor_id") @db.Uuid
  titulo      String   @db.VarChar(80)
  contenido   String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([profesorId])
  @@map("plantillas_mensaje")
}

model Promocion {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId   String   @map("profesor_id") @db.Uuid
  porcentaje   Int      @db.SmallInt // 5-50%
  activa       Boolean  @default(true)
  expiraEn     DateTime? @map("expira_en") @db.Timestamptz()
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([profesorId])
  @@map("promociones")
}

enum PlanSuscripcion {
  GRATIS
  ESTUDIANTE_PRO
  PROFESOR_PLUS
}

model AuditoriaLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId   String?  @map("usuario_id") @db.Uuid
  accion      String   @db.VarChar(80)
  entidad     String   @db.VarChar(80)
  entidadId   String?  @map("entidad_id") @db.VarChar(80)
  metadata    Json?
  ip          String?  @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([usuarioId])
  @@index([accion])
  @@index([createdAt])
  @@map("auditoria_logs")
}

model Suscripcion {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId   String          @unique @map("usuario_id") @db.Uuid
  plan         PlanSuscripcion @default(GRATIS)
  activa       Boolean         @default(true)
  inicioEn     DateTime        @default(now()) @map("inicio_en") @db.Timestamptz()
  expiraEn     DateTime?       @map("expira_en") @db.Timestamptz()
  precioMensual Decimal        @default(0) @map("precio_mensual") @db.Decimal(8, 2)
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("suscripciones")
}

model Ejercicio {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  autorId     String   @map("autor_id") @db.Uuid
  materia     String   @db.VarChar(80)
  nivel       String   @db.VarChar(20)
  titulo      String   @db.VarChar(200)
  enunciado   String
  solucion    String?
  archivoUrl  String?  @map("archivo_url")
  dificultad  Int      @default(1) @db.SmallInt // 1-5
  vistas      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([materia, nivel])
  @@map("ejercicios")
}

model Logro {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId   String   @map("usuario_id") @db.Uuid
  tipo        String   @db.VarChar(40)
  titulo      String   @db.VarChar(120)
  descripcion String
  iconoEmoji  String   @default("🏆") @map("icono_emoji") @db.VarChar(10)
  desbloqueado DateTime @default(now()) @map("desbloqueado") @db.Timestamptz()

  @@unique([usuarioId, tipo])
  @@index([usuarioId])
  @@map("logros")
}

model Bundle {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profesorId    String   @map("profesor_id") @db.Uuid
  nombre        String   @db.VarChar(120)
  numSesiones   Int      @map("num_sesiones") @db.SmallInt
  duracionMin   Int      @default(60) @map("duracion_min")
  precioTotal   Decimal  @map("precio_total") @db.Decimal(10, 2)
  descripcion   String?
  activa        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([profesorId, activa])
  @@map("bundles")
}

model Mensaje {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sesionId    String?  @map("sesion_id") @db.Uuid
  remitenteId String   @map("remitente_id") @db.Uuid
  destinatarioId String? @map("destinatario_id") @db.Uuid
  contenido   String
  leido       Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  sesion      Sesion?  @relation(fields: [sesionId],    references: [id], onDelete: Cascade)
  remitente   Usuario  @relation("MensajesEnviados",    fields: [remitenteId], references: [id], onDelete: Cascade)

  @@index([destinatarioId, leido])
  @@map("mensajes")
}

model Resena {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sesionId      String   @unique @map("sesion_id") @db.Uuid
  estudianteId  String   @map("estudiante_id") @db.Uuid
  profesorId    String   @map("profesor_id") @db.Uuid
  calificacion  Int      @db.SmallInt
  comentario    String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  sesion        Sesion         @relation(fields: [sesionId],     references: [id], onDelete: Cascade)
  estudiante    Usuario        @relation("EstudianteResenas",    fields: [estudianteId], references: [id], onDelete: Cascade)
  profesor      PerfilProfesor @relation("ProfesorResenas",      fields: [profesorId],   references: [id], onDelete: Cascade)

  @@map("resenas")
}
