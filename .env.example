# ProfeLink — variables de entorno
# Copia este archivo a .env.local y rellena los valores

# ── Base de datos ───────────────────────────────────────────────
DATABASE_URL=postgresql://profelink:profelink@localhost:5432/profelink

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_algo_largo_y_aleatorio

# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (emails) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=ProfeLink <hola@profelink.pyecommerce.com>

# ── Gemini (IA para verificación de credenciales) ───────────────
# Obtén tu key en https://aistudio.google.com/apikey (gratis)
GEMINI_API_KEY=

# ── Daily.co (videollamadas embebidas, opcional) ────────────────
# Si no se configuran, hace fallback a Jitsi público en pestaña nueva.
# Crea cuenta gratis en https://dashboard.daily.co/signup
# Tu subdomain está en Settings → Domain (ej: "profelink")
# API key está en Developers
DAILY_API_KEY=
DAILY_SUBDOMAIN=

# ── Storage (gcp opcional) ──────────────────────────────────────
STORAGE_DRIVER=local
# GCS_BUCKET=profelink-uploads
