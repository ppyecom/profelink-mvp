# ProfeLink — variables de entorno
# Copia este archivo a .env.local y rellena los valores

# ── Base de datos ───────────────────────────────────────────────
DATABASE_URL=postgresql://profelink:profelink@localhost:5432/profelink

# ── Auth ────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_algo_largo_y_aleatorio

# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google OAuth ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (emails) ─────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=ProfeLink <hola@profelink.pyecommerce.com>

# ── Gemini (IA principal — verificación, búsqueda, plan, asistente) ─
# Obtén tu key en https://aistudio.google.com/apikey (gratis)
GEMINI_API_KEY=

# ── Groq (IA de failover, opcional pero recomendado) ────────────
# Si Gemini está saturado se cae a Groq (Llama 3.3 70B) automáticamente.
# Tier gratis: 30 req/min, 14,400/día. Crea cuenta en https://console.groq.com
GROQ_API_KEY=

# ── Storage (gcp opcional) ──────────────────────────────────────
STORAGE_DRIVER=local
# GCS_BUCKET=profelink-uploads
